---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Carousel from "../components/Carousel.tsx";
import SocialGrid from "../components/SocialGrid.astro";
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);

// 1. Fetch Data
const homeData = await reader.singletons.homePage.read();
const galleryEntries = await reader.collections.socialGallery.all();

// 2. Map Carousel Data (with fallbacks)
const carouselImages = homeData?.carouselImages?.length 
  ? homeData.carouselImages 
  : [
      "https://images.unsplash.com/photo-1523580494863-6f3031224c94?q=80&w=2000&auto=format&fit=crop",
      "https://images.unsplash.com/photo-1511632765486-a01980e01a18?q=80&w=2000&auto=format&fit=crop"
    ];

// 3. Map Social Grid Data (with fallbacks)
const socialImages = galleryEntries.length > 0
  ? galleryEntries.map(entry => ({
      image: entry.entry.image || "",
      link: entry.entry.link || undefined
    }))
  : [
      { image: "https://images.unsplash.com/photo-1523580494863-6f3031224c94?q=80&w=800" },
      { image: "https://images.unsplash.com/photo-1511632765486-a01980e01a18?q=80&w=800" },
      { image: "https://images.unsplash.com/photo-1544928147-79a2dbc1f389?q=80&w=800" },
      { image: "https://images.unsplash.com/photo-1517486808906-6ca8b3f04846?q=80&w=800" }
    ];
---

<BaseLayout title="Antioch | Oregon State">
  <main>
    <Hero 
      title={homeData?.heroTitle || "Brotherhood"} 
      description={homeData?.heroDescription || "Oregon State University's premier Christian fraternity."}
      backgroundImageUrl={homeData?.heroImage || "https://images.unsplash.com/photo-1523580494863-6f3031224c94?q=80&w=2000&auto=format&fit=crop"}
    />
    
    <section class="py-32 px-6 max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight text-zinc-900 mb-8">
        More than just a house.
      </h2>
      <p class="text-xl md:text-2xl text-zinc-500 font-medium leading-relaxed">
        We are a community dedicated to spiritual growth, academic excellence, and lifelong bonds. Experience college differently.
      </p>
    </section>

	<section class="py-24 border-y border-zinc-200 bg-zinc-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-12 md:gap-8 text-center">
          
          <div>
            <p class="text-5xl md:text-7xl font-black text-zinc-900 tracking-tighter mb-4">370<span class="text-orange-600">+</span></p>
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-zinc-500">Alumni & Members</p>
          </div>
          
          <div>
            <p class="text-5xl md:text-7xl font-black text-zinc-900 tracking-tighter mb-4">3.4</p>
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-zinc-500">Average GPA</p>
          </div>
          
          <div>
            <p class="text-5xl md:text-7xl font-black text-zinc-900 tracking-tighter mb-4">9</p>
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-zinc-500">Small Groups</p>
          </div>
          
          <div>
            <p class="text-5xl md:text-7xl font-black text-zinc-900 tracking-tighter mb-4">47</p>
            <p class="text-xs font-bold uppercase tracking-[0.15em] text-zinc-500">Current Residents</p>
          </div>

        </div>
      </div>
    </section>

    <section class="pb-32 max-w-7xl mx-auto overflow-hidden">
      <Carousel client:load images={carouselImages} />
    </section>

    <section class="py-32 px-6 max-w-7xl mx-auto">
      <div class="text-center mb-20">
        <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-zinc-900 mb-6">Get Involved</h2>
        <p class="text-xl text-zinc-500 max-w-2xl mx-auto leading-relaxed">
          From intramural sports and house dances to Greek philanthropies, there is always a way to connect and grow.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-8">
        
        <div class="p-12 border border-zinc-200 rounded-[2rem] hover:border-orange-600 hover:shadow-2xl hover:shadow-orange-600/10 transition-all duration-300">
          <h3 class="text-lg font-bold uppercase tracking-widest text-zinc-900 mb-4">Intramurals</h3>
          <p class="text-zinc-500 leading-relaxed">
            Compete alongside brothers in OSU's intramural leagues. Build teamwork and character on and off the field.
          </p>
        </div>

        <div class="p-12 border border-zinc-200 rounded-[2rem] hover:border-orange-600 hover:shadow-2xl hover:shadow-orange-600/10 transition-all duration-300">
          <h3 class="text-lg font-bold uppercase tracking-widest text-zinc-900 mb-4">House Events</h3>
          <p class="text-zinc-500 leading-relaxed">
            Create lifelong memories at our house dances, brotherhood retreats, and community dinners.
          </p>
        </div>

        <div class="p-12 border border-zinc-200 rounded-[2rem] hover:border-orange-600 hover:shadow-2xl hover:shadow-orange-600/10 transition-all duration-300">
          <h3 class="text-lg font-bold uppercase tracking-widest text-zinc-900 mb-4">Philanthropy</h3>
          <p class="text-zinc-500 leading-relaxed">
            Engage with the Corvallis community through dedicated service projects and Greek philanthropy events.
          </p>
        </div>

      </div>
    </section>

    <section class="py-24 px-6 max-w-7xl mx-auto">
      <div class="flex justify-between items-end mb-12">
        <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter">Life at Antioch</h2>
        <a href="https://instagram.com/your_handle" target="_blank" class="text-orange-600 font-bold tracking-wide hover:text-zinc-900 transition-colors">
          @ANTIOCH_OSU →
        </a>
      </div>
      
      <SocialGrid images={socialImages} />
    </section>

    <section class="py-32 bg-zinc-900 text-white text-center px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-8">Ready to Join?</h2>
        
        <a 
          href="/apply" 
          class="inline-block px-10 py-4 rounded-full text-lg font-bold uppercase tracking-widest border border-orange-500 text-orange-500 hover:bg-orange-500 hover:text-white transition-colors duration-300"
        >
          Start Application
        </a>
        
      </div>
    </section>
  </main>
</BaseLayout>