---
import BaseLayout from "../layouts/BaseLayout.astro";
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const applyData = await reader.singletons.applyPage.read();

// Fallback just in case it isn't filled out in Keystatic yet
const externalFormUrl = applyData?.formUrl || "#";
---

<BaseLayout title="Apply | Antioch">
  <main class="min-h-[80vh] flex items-center justify-center px-6 pt-32 pb-24">
    
    <div class="max-w-3xl w-full text-center">
      
      <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-zinc-900 mb-8">
        Take the Next Step
      </h1>
      
      <p class="text-xl md:text-2xl text-zinc-500 mb-12 leading-relaxed">
        Applications for the upcoming term are currently open. Fill out our intake form and our recruitment chair will reach out to schedule a tour.
      </p>

      <a 
        href={externalFormUrl} 
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-12 py-5 rounded-full text-lg font-bold uppercase tracking-widest border border-orange-600 text-orange-600 hover:bg-orange-600 hover:text-white transition-colors duration-300"
      >
        Open Application Form
      </a>

    </div>
    
  </main>
</BaseLayout>