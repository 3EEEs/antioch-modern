---
import BaseLayout from "../layouts/BaseLayout.astro";

const values = [
  { title: "Brotherhood", text: "Lifelong relationships built on shared values and mutual respect." },
  { title: "Discipleship", text: "Growing together in faith and challenging each other daily." },
  { title: "Excellence", text: "Pushing the boundaries in our academic and personal lives." },
];
---
<BaseLayout title="About Us | Antioch">
  <main class="pt-32 pb-24 px-6 max-w-7xl mx-auto">
    
    <div class="max-w-4xl mb-24">
      <h1 class="text-6xl md:text-8xl font-black uppercase tracking-tighter mb-8">Our Mission</h1>
      <p class="text-2xl text-zinc-500 leading-relaxed font-medium">
        Antioch House is more than a residence. We are a community of men at Oregon State University dedicated to forging iron-sharpens-iron relationships. 
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-12 mt-24">
      {values.map(value => (
        <div class="bg-white p-10 rounded-3xl shadow-sm border border-zinc-100 hover:shadow-xl transition-shadow duration-300">
          <div class="w-12 h-12 bg-orange-100 rounded-full mb-6 flex items-center justify-center">
             <div class="w-4 h-4 bg-orange-600 rounded-full animate-pulse" />
          </div>
          <h3 class="text-2xl font-bold text-zinc-900 mb-4">{value.title}</h3>
          <p class="text-zinc-500 text-lg">{value.text}</p>
        </div>
      ))}
    </div>

  </main>
</BaseLayout>