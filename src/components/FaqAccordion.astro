---
export interface Props {
  faqs: { question: string; answer: string }[];
}
const { faqs = [] } = Astro.props;
---
<div class="max-w-3xl mx-auto divide-y divide-zinc-200">
  {faqs.map((faq) => (
    <details class="group py-6 [&_summary::-webkit-details-marker]:hidden">
      <summary class="flex items-center justify-between cursor-pointer list-none">
        <h3 class="text-xl font-bold text-zinc-900 group-open:text-orange-600 transition-colors">
          {faq.question}
        </h3>
        <span class="relative flex-shrink-0 ml-1.5 w-5 h-5">
          <svg class="absolute inset-0 w-5 h-5 opacity-100 group-open:opacity-0 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          <svg class="absolute inset-0 w-5 h-5 opacity-0 group-open:opacity-100 transition-opacity duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4" />
          </svg>
        </span>
      </summary>
      <div class="mt-4 text-zinc-500 leading-relaxed text-lg animate-[fadeIn_0.3s_ease-in-out]">
        <p>{faq.answer}</p>
      </div>
    </details>
  ))}
</div>